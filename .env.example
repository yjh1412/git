# Server
APP_HOST=127.0.0.1
APP_PORT=8000

# Default: no LLM if LLM_BASE_URL / LLM_MODEL are not configured.
# OpenAI-compatible local model services can use any non-empty token.
LLM_API_KEY=local

# MiniMax-M3 served by vLLM or another OpenAI-compatible runtime.
LLM_BASE_URL=http://127.0.0.1:8001/v1
LLM_MODEL=minimax-m3

